class ErrorPatternAnalyzer:
    """Learn from repeated validation failures to improve prompts"""
    
    def __init__(self):
        self.error_patterns = defaultdict(list)
        self.fix_templates = defaultdict(list)
        self.retry_success_rates = {}
    
    def record_error_cycle(self, error_type: str, code_before: str, 
                          code_after: str, success: bool, context: Dict[str, Any]):
        """Build a library of error->fix patterns"""
        
        if success:
            # Extract the fix pattern
            fix_pattern = self._extract_diff_pattern(code_before, code_after)
            context_hash = hashlib.md5(json.dumps(context, sort_keys=True).encode()).hexdigest()[:8]
            
            pattern_id = f"{error_type}_{context_hash}"
            
            self.fix_templates[error_type].append({
                "pattern_id": pattern_id,
                "fix_pattern": fix_pattern,
                "fix_code": code_after,
                "context": context,
                "timestamp": datetime.now(),
                "usage_count": 0
            })
            
            # Keep only top 5 fixes per error type
            if len(self.fix_templates[error_type]) > 5:
                self.fix_templates[error_type] = sorted(
                    self.fix_templates[error_type],
                    key=lambda x: x["usage_count"],
                    reverse=True
                )[:5]
    
    def generate_targeted_fix_prompt(self, error: Dict[str, Any], 
                                    current_code: str, context: Dict[str, Any]) -> str:
        """Use historical fixes to guide LLM with specific patterns"""
        
        error_type = error.get("type", "unknown")
        similar_fixes = self._find_similar_fixes(error_type, context)
        
        if not similar_fixes:
            return self._generate_generic_fix_prompt(error, current_code)
        
        # Increment usage count for successful patterns
        for fix in similar_fixes:
            fix["usage_count"] += 1
        
        return f"""
# SPECIFIC FIX REQUIRED: {error_type.upper()}
# Error: {error.get('message', 'Unknown error')}
# Location: Line {error.get('line', 'unknown')}

## PREVIOUSLY SUCCESSFUL FIXES FOR THIS ERROR:

{self._format_fix_examples(similar_fixes)}

## YOUR CURRENT CODE (WITH ERROR):

{self._annotate_error_in_code(current_code, error)}

## REQUIRED ACTION:
Apply the most relevant fix pattern from above to your code.
Focus on correcting: {error.get('fix_suggestion', 'the identified issue')}

## CONSTRAINTS TO MAINTAIN:
{context.get('constraints_summary', 'All original constraints apply')}

## GENERATE CORRECTED CODE:
"""
    
    def _extract_diff_pattern(self, before: str, after: str) -> Dict[str, Any]:
        """Extract the minimal change pattern from before/after code"""
        # Simplified diff extraction - in production use difflib
        before_lines = before.split('\n')
        after_lines = after.split('\n')
        
        pattern = {
            "changed_lines": [],
            "pattern_type": "unknown",
            "structural_change": False
        }
        
        for i, (b, a) in enumerate(zip(before_lines, after_lines)):
            if b != a:
                pattern["changed_lines"].append({
                    "line": i + 1,
                    "before": b[:100],  # Truncate
                    "after": a[:100]
                })
        
        return pattern
    
    def _find_similar_fixes(self, error_type: str, context: Dict[str, Any]) -> List[Dict[str, Any]]:
        """Find fixes for similar errors in similar context"""
        fixes = self.fix_templates.get(error_type, [])
        
        if not fixes:
            # Try to find similar error types
            for et in self.fix_templates.keys():
                if error_type in et or et in error_type:
                    fixes.extend(self.fix_templates[et])
        
        # Sort by usage count (most successful first)
        return sorted(fixes, key=lambda x: x["usage_count"], reverse=True)[:3]
    
    def _format_fix_examples(self, fixes: List[Dict[str, Any]]) -> str:
        """Format fix examples for prompt inclusion"""
        formatted = []
        for i, fix in enumerate(fixes, 1):
            pattern = fix.get("fix_pattern", {})
            formatted.append(f"""
### Fix Pattern #{i} (Used {fix['usage_count']} times successfully):
**Change Type:** {pattern.get('pattern_type', 'unknown')}
**Lines Changed:** {len(pattern.get('changed_lines', []))}

**Before:**
```python
{self._extract_before_snippet(fix.get('fix_code', ''))}
```

After:

```python
{self._extract_after_snippet(fix.get('fix_code', ''))}
```

Context: {json.dumps(fix.get('context', {}).get('component_type', 'unknown'), indent=2)}
""")
return '\n'.join(formatted)

FIX REQUIRED

Error: {error.get('message', 'Unknown error')}
Suggestion: {error.get('fix_suggestion', 'Review the code')}

Code with error:
{current_code}

Please fix the error while maintaining all original constraints.
"""

