class AdaptiveTokenBudget:
    """Dynamically allocate token budget across context sections"""
    
    BUDGET_ALLOCATION = {
        "contract_interface": 0.20,      # Always prioritize
        "constraints": 0.15,
        "working_examples": 0.25,        # LLMs learn best from examples
        "dependencies": 0.15,
        "error_context": 0.15,           # Previous errors if retry
        "system_context": 0.10
    }
    
    def __init__(self, max_tokens: int = 128000):
        self.max_tokens = max_tokens
        self.usage_history = []
    
    def allocate_tokens(self, task_type: str, retry_count: int = 0) -> Dict[str, int]:
        """Adjust allocation based on task complexity and retry status"""
        adjusted = self.BUDGET_ALLOCATION.copy()
        
        if retry_count > 0:
            # Increase error context on retry
            adjusted["error_context"] = 0.30
            adjusted["working_examples"] = 0.15
        
        if task_type == "contract_generation":
            adjusted["contract_interface"] = 0.35
            adjusted["system_context"] = 0.05
        
        if task_type == "debugging":
            adjusted["error_context"] = 0.40
            adjusted["working_examples"] = 0.20
        
        # Calculate token counts
        allocation = {}
        for section, percentage in adjusted.items():
            allocation[section] = int(self.max_tokens * percentage)
        
        self.usage_history.append({
            "task_type": task_type,
            "retry_count": retry_count,
            "allocation": allocation,
            "timestamp": datetime.now()
        })
        
        return allocation
    
    def compress_context(self, context: Dict[str, Any], target_tokens: int) -> Dict[str, Any]:
        """Intelligently compress context to fit token budget"""
        compressed = {}
        
        for section, content in context.items():
            if isinstance(content, str) and len(content) > 1000:
                # Truncate long sections intelligently
                if section == "working_examples":
                    compressed[section] = self._truncate_examples(content, target_tokens // 3)
                elif section == "error_context":
                    compressed[section] = self._summarize_errors(content)
                else:
                    compressed[section] = content[:target_tokens // 2]
            else:
                compressed[section] = content
        
        return compressed
    
    def _truncate_examples(self, examples: str, max_chars: int) -> str:
        """Truncate examples while preserving key patterns"""
        lines = examples.split('\n')
        important_lines = [l for l in lines if any(marker in l.lower() 
                          for marker in ['def ', 'class ', 'import ', '# critical', '@'])]
        
        if len(important_lines) > 10:
            important_lines = important_lines[:10]
        
        truncated = '\n'.join(important_lines)
        if len(truncated) > max_chars:
            truncated = truncated[:max_chars] + "\n# ... truncated for token budget"
        
        return truncated
    
    def _summarize_errors(self, errors: str) -> str:
        """Summarize error context"""
        if len(errors) < 500:
            return errors
        
        # Extract just error types and fixes
        lines = errors.split('\n')
        summary = []
        for line in lines:
            if 'ERROR:' in line or 'FIX:' in line or 'Line' in line:
                summary.append(line)
        
        return '\n'.join(summary[:20])  # Keep top 20 errors

